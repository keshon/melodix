#
# DEPLOY SETTINGS
#

# Docker container name - don't need if the .env file is used localy
ALIAS=melodix

# Set GIT to true to pull sources from git repository, local 'src' dir will be used otherwise if was pulled before
GIT=true
GIT_URL=https://github.com/keshon/melodix.git


#
# BOT SETTINGS
#

# .env
# Discord bot token
DISCORD_TOKEN=123

# Storage path
# Default: ./data/datastore.json
STORAGE_PATH=./data/datastore.json

# Register Discord slash commands
INIT_SLASH_COMMANDS=true
