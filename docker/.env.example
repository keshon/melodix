#
# DEPLOY SETTINGS
#

# Docker container name (used for container_name and image tag)
ALIAS=melodix

# Set GIT=true to clone from GIT_URL into ./src; set GIT=false to use existing ./src (e.g. local copy)
GIT=true
GIT_URL=https://github.com/keshon/melodix.git

#
# BOT SETTINGS (match main .env / README)
#

# Required: Discord bot token from Developer Portal
DISCORD_TOKEN=your-discord-bot-token

# Path for bot data inside the container (default below)
STORAGE_PATH=/usr/project/data/datastore.json

# Register slash commands on startup (true/false)
INIT_SLASH_COMMANDS=false

# Optional: comma-separated guild IDs the bot will leave
# DISCORD_GUILD_BLACKLIST=

# Optional: your Discord user ID for developer-only commands
# DEVELOPER_ID=

# Optional: ms to wait after joining VC before sending audio (default 500)
# VOICE_READY_DELAY_MS=500
